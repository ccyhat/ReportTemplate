<UserControl x:Class="ReportTemplate.MainWindow.Views.XMLTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ReportTemplate.MainWindow.Views"
             xmlns:vm="clr-namespace:ReportTemplate.MainWindow.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="400" 
             d:DesignWidth="250"
             Background="White">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type vm:XmlTreeNodeViewModel}" 
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <TextBlock Text="📄" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#333333"/>
                <TextBlock Text=" (" Foreground="#999999"/>
                <TextBlock Text="{Binding Type}" Foreground="#666666" FontStyle="Italic"/>
                <TextBlock Text=")" Foreground="#999999"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" 
                Background="#F0F0F0" 
                Padding="8,6">
            <TextBlock Text="XML 结构" 
                       FontWeight="SemiBold"
                       Foreground="#333333"/>
        </Border>
        
        <!-- 树形视图 -->
        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding Nodes}"
                  BorderThickness="0"
                  Background="White"
                  Foreground="#333333">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True"/>
                    <Setter Property="Padding" Value="4"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>
