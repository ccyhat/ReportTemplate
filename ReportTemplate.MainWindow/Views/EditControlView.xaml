<UserControl x:Class="ReportTemplate.MainWindow.Views.EditControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ReportTemplate.MainWindow.Views"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             xmlns:winforms="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             xmlns:cm="http://www.caliburnproject.org"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="600"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0"
                Background="#F0F0F0"
                Padding="8,6"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Word 编辑器"
                           FontWeight="SemiBold"
                           Foreground="#333333"/>
                <TextBlock Text=" - " Foreground="#999999" Margin="5,0,0,0"/>
                <TextBlock Text="{Binding FilePath}"
                           Foreground="#666666"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- 下方主显示区：分为左右两部分 (1:4) -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <!-- 左侧列表区域 -->
                <ColumnDefinition Width="5"/>
                <!-- 分割条宽度 -->
                <ColumnDefinition Width="4*"/>
                <!-- 右侧 Word 区域 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧列表区域 -->
            <Border Grid.Column="0"
                    BorderBrush="#FFCCCCCC"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="White">
                <ListBox ItemsSource="{Binding TemplateList}"
                         Margin="5"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="cm:Message.Attach"
                                    Value="[Event MouseDoubleClick] = [Action TemplateList_DoubleClick($dataContext)]"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="5" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- 可拖动的分割条 -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          Background="LightGray"
                          HorizontalAlignment="Stretch"
                          ShowsPreview="True"/>

            <!-- 右侧 Word 嵌入区域 -->
            <Border Grid.Column="2"
                    BorderBrush="#FFCCCCCC"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="White">
                <wfi:WindowsFormsHost x:Name="WordHostControl">
                    <winforms:Panel Dock="Fill" />
                </wfi:WindowsFormsHost>
            </Border>
        </Grid>
    </Grid>
</UserControl>
